# ============================================
# Agent Service - Environment Variables
# ============================================
# NEVER commit .env with real credentials
# Copy this to .env and fill with actual values
# ============================================

# Application
APP_ENV=local
SERVICE_NAME=agent-service
LOG_LEVEL=INFO

# AWS Configuration
# For local: Use LocalStack
# For dev/prod: Use IAM roles (IRSA in EKS)
AWS_REGION=ap-northeast-2
# NOTE: Do NOT set AWS_ACCESS_KEY_ID or AWS_SECRET_ACCESS_KEY here
# Local: AWS CLI configured credentials or LocalStack
# EKS: Use IAM Roles for Service Accounts (IRSA)

# Bedrock
BEDROCK_REGION=us-west-2
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=
BEDROCK_KNOWLEDGE_BASE_ID=
ENABLE_BEDROCK_MOCK=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=3600

# DynamoDB
DYNAMODB_ENDPOINT_URL=http://localhost:8000
DYNAMODB_AGENT_INTERACTIONS_TABLE=gympt-agent-interactions-local

# SQS
SQS_ENDPOINT_URL=http://localhost:4566
SQS_AGENT_TASK_QUEUE_URL=http://localhost:4566/000000000000/gympt-agent-tasks-local

# Backend API
BACKEND_API_BASE_URL=http://localhost:8080
BACKEND_API_TIMEOUT=30
INTERNAL_API_TOKEN=

# Cache Configuration
CACHE_TTL_SECONDS=3600

# Retry Configuration
MAX_RETRIES=3
BACKOFF_FACTOR=2

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=30
