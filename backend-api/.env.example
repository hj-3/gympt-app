# ============================================
# Backend API - Environment Variables
# ============================================
# Service-specific environment variables
# Common variables are in root .env.example
# ============================================

# Service Identity
SERVICE_NAME=backend-api
SERVER_PORT=8080

# Spring Profile
SPRING_PROFILES_ACTIVE=local           # local | dev | prod

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gympt
DB_USERNAME=gympt_user
DB_PASSWORD=changeme_local_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=local_jwt_secret_change_this_in_production
JWT_ACCESS_TOKEN_TTL_SECONDS=3600
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000

# AWS Services
AWS_REGION=ap-northeast-2

# DynamoDB
DYNAMODB_ENDPOINT_URL=http://localhost:4566
DYNAMODB_WORKOUT_SESSIONS_TABLE=gympt-workout-sessions-local
DYNAMODB_POSTURE_EVENTS_TABLE=gympt-posture-events-local
DYNAMODB_WEARABLE_EVENTS_TABLE=gympt-wearable-events-local
DYNAMODB_AGENT_INTERACTIONS_TABLE=gympt-agent-interactions-local

# S3
S3_ENDPOINT_URL=http://localhost:4566
S3_MEDIA_BUCKET=gympt-media-local
S3_REPORT_BUCKET=gympt-reports-local

# SQS
SQS_ENDPOINT_URL=http://localhost:4566
SQS_POSTURE_EVENT_QUEUE_URL=http://localhost:4566/000000000000/gympt-posture-events-local
SQS_REPORT_GENERATION_QUEUE_URL=http://localhost:4566/000000000000/gympt-report-generation-local

# EventBridge
EVENTBRIDGE_ENDPOINT_URL=http://localhost:4566
EVENTBRIDGE_BUS_NAME=gympt-events-local

# Microservice URLs
AGENT_SERVICE_BASE_URL=http://localhost:8001
POSTURE_ANALYSIS_SERVICE_BASE_URL=http://localhost:8002
REPORT_SERVICE_BASE_URL=http://localhost:8003
NOTIFICATION_SERVICE_BASE_URL=http://localhost:8004

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=INFO
ENABLE_SQL_LOGGING=false

# API Documentation
ENABLE_API_DOCS=true
