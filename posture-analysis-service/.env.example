# ============================================
# Posture Analysis Service - Environment Variables
# ============================================
# NEVER commit .env with real credentials
# Copy this to .env and fill with actual values
# ============================================

# Application
APP_ENV=local
SERVICE_NAME=posture-analysis-service
LOG_LEVEL=INFO

# Hardware
ENABLE_GPU=false
MODEL_TYPE=mock

# AWS Configuration
# For local: Use LocalStack
# For dev/prod: Use IAM roles (IRSA in EKS)
AWS_REGION=ap-northeast-2
# NOTE: Do NOT set AWS_ACCESS_KEY_ID or AWS_SECRET_ACCESS_KEY here
# Local: AWS CLI configured credentials or LocalStack
# EKS: Use IAM Roles for Service Accounts (IRSA)

# Kinesis Video Streams
KVS_SIGNALING_CHANNEL_NAME=
KVS_SIGNALING_CHANNEL_ARN=
ENABLE_KVS_MOCK=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# DynamoDB
DYNAMODB_ENDPOINT_URL=http://localhost:8000
DYNAMODB_POSTURE_EVENTS_TABLE=gympt-posture-events-local

# S3
S3_ENDPOINT_URL=http://localhost:4566
S3_MEDIA_BUCKET=gympt-media-local
S3_POSTURE_RESULTS_PREFIX=posture-results

# SQS
SQS_ENDPOINT_URL=http://localhost:4566
SQS_POSTURE_EVENT_QUEUE_URL=http://localhost:4566/000000000000/gympt-posture-events-local

# Analysis
FRAME_PROCESSING_INTERVAL=0.1
FEEDBACK_THRESHOLD_SCORE=7.0
MAX_WEBSOCKET_CONNECTIONS=100
