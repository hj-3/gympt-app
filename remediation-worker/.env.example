# ============================================
# Remediation Worker - Environment Variables
# ============================================
# Auto-remediation worker for system health monitoring
# ============================================

# Service Identity
SERVICE_NAME=remediation-worker

# Environment
APP_ENV=local
LOG_LEVEL=INFO

# AWS Configuration
AWS_REGION=ap-northeast-2

# Check Interval
CHECK_INTERVAL_SECONDS=60
REMEDIATION_ENABLED=true

# Service URLs
BACKEND_API_BASE_URL=http://localhost:8080
PROMETHEUS_BASE_URL=http://localhost:9090

# Health Check Thresholds
CPU_THRESHOLD_PERCENT=80
MEMORY_THRESHOLD_PERCENT=85
DISK_THRESHOLD_PERCENT=90
POD_RESTART_THRESHOLD=5

# Remediation Actions
ENABLE_AUTO_RESTART=false              # Dangerous in prod
ENABLE_AUTO_SCALE=true
ENABLE_ALERT_ONLY=true

# Kubernetes
KUBECONFIG_PATH=
KUBE_NAMESPACE=gympt-dev

# Slack Notifications
SLACK_WEBHOOK_URL=                     # From Kubernetes Secret in AWS

# Monitoring
PROMETHEUS_ENABLED=true
