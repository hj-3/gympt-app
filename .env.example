# ============================================
# GYMPT - Environment Variables Template
# ============================================
# Copy this file to .env and fill in actual values
# NEVER commit .env to version control
#
# Usage:
#   cp .env.example .env
#   vim .env  # Edit with actual values
#
# For AWS environments, these values are managed by:
#   - AWS Secrets Manager (sensitive data)
#   - AWS Systems Manager Parameter Store (configuration)
#   - External Secrets Operator (Kubernetes)
# ============================================

# ============================================
# Common Configuration
# ============================================
APP_ENV=local                          # local | dev | prod
AWS_REGION=ap-northeast-2
AWS_ACCOUNT_ID=123456789012           # Your AWS Account ID
PROJECT_NAME=gympt
LOG_LEVEL=INFO                         # DEBUG | INFO | WARN | ERROR

# ============================================
# Database - PostgreSQL
# ============================================
# Local: docker-compose PostgreSQL
# AWS: RDS PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gympt
DB_USERNAME=gympt_user
DB_PASSWORD=changeme_local_password   # Use strong password in AWS

# ============================================
# Cache - Redis
# ============================================
# Local: docker-compose Redis
# AWS: ElastiCache Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                        # Empty for local, required in AWS

# ============================================
# Object Storage - S3
# ============================================
# Local: LocalStack S3
# AWS: Amazon S3
S3_MEDIA_BUCKET=gympt-media-local
S3_REPORT_BUCKET=gympt-reports-local
S3_THUMBNAIL_BUCKET=gympt-thumbnails-local
S3_EXPORT_BUCKET=gympt-exports-local
S3_ENDPOINT_URL=http://localhost:4566 # LocalStack, remove for AWS

# ============================================
# NoSQL - DynamoDB
# ============================================
# Local: LocalStack DynamoDB
# AWS: Amazon DynamoDB
DYNAMODB_ENDPOINT_URL=http://localhost:4566  # LocalStack, remove for AWS
DYNAMODB_WORKOUT_SESSIONS_TABLE=gympt-workout-sessions-local
DYNAMODB_POSTURE_EVENTS_TABLE=gympt-posture-events-local
DYNAMODB_WEARABLE_EVENTS_TABLE=gympt-wearable-events-local
DYNAMODB_AGENT_INTERACTIONS_TABLE=gympt-agent-interactions-local

# ============================================
# Message Queue - SQS
# ============================================
# Local: LocalStack SQS
# AWS: Amazon SQS
SQS_ENDPOINT_URL=http://localhost:4566  # LocalStack, remove for AWS
SQS_POSTURE_EVENT_QUEUE_URL=http://localhost:4566/000000000000/gympt-posture-events-local
SQS_REPORT_GENERATION_QUEUE_URL=http://localhost:4566/000000000000/gympt-report-generation-local
SQS_AGENT_TASK_QUEUE_URL=http://localhost:4566/000000000000/gympt-agent-tasks-local
SQS_NOTIFICATION_QUEUE_URL=http://localhost:4566/000000000000/gympt-notifications-local
SQS_WEARABLE_SYNC_QUEUE_URL=http://localhost:4566/000000000000/gympt-wearable-sync-local

# ============================================
# Event Bus - EventBridge
# ============================================
# Local: LocalStack EventBridge
# AWS: Amazon EventBridge
EVENTBRIDGE_ENDPOINT_URL=http://localhost:4566  # LocalStack, remove for AWS
EVENTBRIDGE_BUS_NAME=gympt-events-local

# ============================================
# Notification - SNS
# ============================================
# Local: LocalStack SNS
# AWS: Amazon SNS
SNS_ENDPOINT_URL=http://localhost:4566  # LocalStack, remove for AWS
SNS_NOTIFICATION_TOPIC_ARN=arn:aws:sns:ap-northeast-2:000000000000:gympt-notifications-local

# ============================================
# Video Streaming - Kinesis Video Streams
# ============================================
# Note: KVS not available in LocalStack, use AWS dev/prod
KVS_SIGNALING_CHANNEL_NAME=gympt-workout-stream-local
KVS_SIGNALING_CHANNEL_ARN=
KVS_REGION=ap-northeast-2

# ============================================
# AI Services - Bedrock
# ============================================
# Note: Bedrock requires actual AWS account
BEDROCK_REGION=us-west-2
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_AGENT_ID=                      # Create in AWS Console
BEDROCK_AGENT_ALIAS_ID=                # Create in AWS Console
BEDROCK_KNOWLEDGE_BASE_ID=             # Create in AWS Console
MOCK_BEDROCK=true                      # Use mock responses for local dev

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET=local_jwt_secret_change_this_in_production_use_256bit_random_string
JWT_ACCESS_TOKEN_TTL_SECONDS=3600      # 1 hour
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000  # 30 days

# ============================================
# Service URLs (Microservices)
# ============================================
# Local: localhost
# AWS: Kubernetes Service DNS
BACKEND_API_BASE_URL=http://localhost:8080
AGENT_SERVICE_BASE_URL=http://localhost:8001
POSTURE_ANALYSIS_SERVICE_BASE_URL=http://localhost:8002
REPORT_SERVICE_BASE_URL=http://localhost:8003
NOTIFICATION_SERVICE_BASE_URL=http://localhost:8004

# ============================================
# Frontend URLs
# ============================================
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# ML/AI Configuration
# ============================================
ENABLE_GPU=false                       # Set true for GPU nodes
MODEL_TYPE=mediapipe                   # mediapipe | openpose
POSTURE_CONFIDENCE_THRESHOLD=0.7
S3_POSTURE_RESULT_PREFIX=posture-results/

# ============================================
# Monitoring & Observability
# ============================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
JAEGER_ENABLED=false
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# ============================================
# Feature Flags
# ============================================
FEATURE_AI_AGENT_ENABLED=true
FEATURE_REALTIME_POSTURE_ENABLED=true
FEATURE_WEARABLE_INTEGRATION_ENABLED=false
FEATURE_AUTO_REMEDIATION_ENABLED=false

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ============================================
# External Integrations
# ============================================
SLACK_WEBHOOK_URL=                     # For alerts and notifications
SENTRY_DSN=                            # For error tracking (optional)

# ============================================
# Development/Testing
# ============================================
ENABLE_DEBUG_MODE=false
ENABLE_SQL_LOGGING=false
ENABLE_API_DOCS=true                   # Swagger/OpenAPI docs
SKIP_AUTH_IN_DEV=false                 # NEVER set true in prod
